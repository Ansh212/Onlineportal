        "activity_text": "Test Started"
    })

    if scenario_type == "normal":
        # Simulate Normal User behavior
        question_indices_to_visit = list(range(len(questions)))
        
        # Simulate occasional non-sequential navigation
        if random.random() < NORMAL_JUMP_PROB * 5: # Allow a few potential shuffles
             random.shuffle(question_indices_to_visit)
             
        # Simulate rare tab switch for the whole test
        did_tab_switch = random.random() < NORMAL_TAB_SWITCH_PROB
        tab_switch_time = 0
        if did_tab_switch:
            tab_switch_time = get_random_time(15, 5) # Duration of switch

        q_idx_pointer = 0
        while current_time_s < time_limit and q_idx_pointer < len(question_indices_to_visit):
            current_question_idx = question_indices_to_visit[q_idx_pointer]
            question = questions[current_question_idx]
            
            # 1. Log selecting the question (if not already the current one implicitly)
            # Add a small delay for clicking/navigating
