def process_log_file(log_data):
    \"\"\"Parses logs to extract per-question metrics for one session.\"\"\"
    logs = log_data.get(\"logs\", [])
    if not logs:
        return {} # Skip if no logs

    session_metrics = defaultdict(lambda: {
